# Copy to `.env.local` (gitignored) for local dev.
# All values are placeholders — never commit real secrets.

# --- Database (Phase 1, wired) ---
# Neon Postgres connection string. The `-pooler` host uses connection pooling.
DATABASE_URL="postgresql://user:password@host.neon.tech/db?sslmode=require"

# --- Auth.js (Phase 1, wired) ---
# Generate AUTH_SECRET with: openssl rand -hex 32
AUTH_SECRET="generate-with-openssl-rand-hex-32"
AUTH_URL="http://localhost:3000"

# --- Email (Phase 1, wired — Hostinger SMTP) ---
EMAIL_SERVER_HOST="smtp.hostinger.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="hello@webstability.eu"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="hello@webstability.eu"

# --- Payments (Phase 6 — Stripe only) ---
# Use sk_test_… while testing, sk_live_… in production.
STRIPE_SECRET_KEY=""
# Webhook secret from `stripe listen` (dev) or Dashboard → Webhooks (prod).
STRIPE_WEBHOOK_SECRET=""
# Price IDs created in Stripe Dashboard → Products. Three recurring monthly prices:
# Care €69/m, Studio €179/m, Atelier €399/m.
STRIPE_PRICE_CARE=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_ATELIER=""
# Build extensions — temporary monthly add-ons during a build phase.
# Light €199/m, Standard €499/m, Custom €899/m.
STRIPE_PRICE_BUILD_LIGHT=""
STRIPE_PRICE_BUILD_STANDARD=""
STRIPE_PRICE_BUILD_CUSTOM=""

# --- Mail audit ---
# Every transactional mail (magic-link, welcome) gets BCC'd here so we
# can review production copy. Default is hello@webstability.eu when
# this var is missing; set to empty string to disable entirely.
MAIL_AUDIT_BCC=""

# --- Monitoring (Phase 2, wired) ---
BETTER_STACK_API_KEY=""

# --- Analytics & error tracking ---
# Plausible: set to your live domain (e.g. "webstability.eu"). Empty = no tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="webstability.eu"
# Sentry: client DSN must be NEXT_PUBLIC_ to be exposed to the browser.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Integrations (later phases, stubbed) ---
DOCUSEAL_API_KEY=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_WEBHOOK_SECRET=""

# --- Storage (Phase 4, optional) ---
# Auto-injected on Vercel. Locally: pull via `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# --- Google Search Console OAuth (per-org, Phase 4+) ---
GSC_OAUTH_CLIENT_ID=""
GSC_OAUTH_CLIENT_SECRET=""

# --- Vercel cron (later phases) ---
CRON_SECRET=""
